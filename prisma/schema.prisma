generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SelfMapEntry {
  id        String   @id @default(cuid())
  category  String   // interests | strengths | aversions | flow | network | other
  question  String
  answer    String
  tags      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProblemCard {
  id           String   @id @default(cuid())
  title        String
  who          String
  when         String
  why          String
  painPoints   String
  alternatives String
  source       String   @default("manual")
  sourceUrl    String   @default("")
  tags         String   @default("")
  stage        String   @default("")
  category     String   @default("")
  addedBy      String   @default("scout")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fitEvaluations      FitEvaluation[]
  hypotheses          Hypothesis[]         // axis: existence | severity (problem-level)
  solutionHypotheses  SolutionHypothesis[]
}

model FitEvaluation {
  id            String   @id @default(cuid())
  problemCardId String   @unique
  attraction    Int
  understanding Int
  accessibility Int
  motivation    Int
  notes         String   @default("")
  totalScore    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  problemCard ProblemCard @relation(fields: [problemCardId], references: [id], onDelete: Cascade)
}

model SolutionHypothesis {
  id            String   @id @default(cuid())
  problemCardId String
  statement     String
  source        String   @default("manual")  // manual | ai_suggested
  status        String   @default("active")  // active | shelved | confirmed | broken
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  problemCard   ProblemCard    @relation(fields: [problemCardId], references: [id], onDelete: Cascade)
  hypotheses    Hypothesis[]                  // axis: fit | willingness (solution-level)
  realityChecks RealityCheck[]
  onePager      OnePager?
}

// Hypothesis represents one of the four validation axes.
// Exactly one parent FK is set: existence/severity attach to ProblemCard;
// fit/willingness attach to SolutionHypothesis. Enforced in zod and at the
// app layer; per-parent unique on (parentId, axis) prevents duplicates.
model Hypothesis {
  id                   String   @id @default(cuid())
  axis                 String   // existence | severity | fit | willingness
  problemCardId        String?
  solutionHypothesisId String?
  prescribedMethods    String   @default("[]")           // JSON array of method keys
  successSignals       String   @default("")
  failureSignals       String   @default("")
  status               String   @default("not_started")  // not_started | in_progress | broken | confirmed
  findings             String   @default("")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  problemCard        ProblemCard?        @relation(fields: [problemCardId], references: [id], onDelete: Cascade)
  solutionHypothesis SolutionHypothesis? @relation(fields: [solutionHypothesisId], references: [id], onDelete: Cascade)
  methodGuides       MethodGuide[]

  @@unique([problemCardId, axis])
  @@unique([solutionHypothesisId, axis])
}

// Per-(Hypothesis, method) execution guide generated by Method Coach.
// Lazy: created on demand when the user asks "어떻게 진행하지?" for a
// specific prescribed method. Steps + a method-specific template (interview
// questions, landing copy, observation script, etc.) + practical hints.
model MethodGuide {
  id           String   @id @default(cuid())
  hypothesisId String
  method       String   // interview | observation | smoke_test | fake_door | prepayment | concierge
  steps        String   // JSON array of strings (3~6 ordered actions)
  template     String   // method-specific raw material (markdown)
  sampleSize   String   @default("")
  channels     String   @default("[]")  // JSON array of strings
  timeEstimate String   @default("")
  watchOuts    String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hypothesis Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)

  @@unique([hypothesisId, method])
}

model RealityCheck {
  id                   String   @id @default(cuid())
  solutionHypothesisId String
  coldInvestor         String
  honestFriend         String
  socraticQ            String
  moderatorSummary     String
  inputContext         String
  createdAt            DateTime @default(now())

  solutionHypothesis SolutionHypothesis @relation(fields: [solutionHypothesisId], references: [id], onDelete: Cascade)
}

// Solution-level 1-pager — drafted by OnePager Composer, edited by user.
// Bridges Desirability (4-axis) to Feasibility/Viability thinking. RC reads
// this as richer context when present; RC FK stays on SolutionHypothesis.
// 10 sections stored as plain text columns (per docs/decisions.md 2026-04-30
// — JSON deferred to v2 if structuring becomes necessary).
model OnePager {
  id                    String   @id @default(cuid())
  solutionHypothesisId  String   @unique
  oneLineSummary        String   @default("")
  targetCustomer        String   @default("")
  problem               String   @default("")
  solution              String   @default("")
  mvpScope              String   @default("")
  mvpCostEstimate       String   @default("")
  operatingModel        String   @default("")
  monetization          String   @default("")
  topRisks              String   @default("")  // 자유 텍스트 (3개를 줄 분리로)
  validationActions30d  String   @default("")  // 자유 텍스트
  draftGeneratedAt      DateTime?
  lastEditedAt          DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  solutionHypothesis SolutionHypothesis @relation(fields: [solutionHypothesisId], references: [id], onDelete: Cascade)
}

model AgentConversation {
  id        String   @id @default(cuid())
  agentType String
  role      String
  content   String
  sessionId String
  createdAt DateTime @default(now())
}

// One Self Map interview session. Mode is decided at start (thread / gap /
// tension / energy) based on prior session metadata + Self Map state. On
// explicit end ("오늘은 여기까지" button), the Synthesizer fills
// threadToResume / tensionCandidates / gapAreas — these become input for the
// next session's mode selection.
//
// JSON columns stored as String (Postgres text); shapes:
//   modeContext        : { categoryHint?: string, tensionPair?: object }
//   threadToResume     : [{ summary: string, relatedEntryIds: string[] }]
//   tensionCandidates  : [{ entryIdA: string, entryIdB: string, description: string }]
//   gapAreas           : [{ category: string, reason: string }]
model InterviewSession {
  id                    String    @id @default(cuid())
  startedAt             DateTime  @default(now())
  endedAt               DateTime?
  mode                  String
  modeContext           String    @default("{}")
  threadToResume        String    @default("[]")
  tensionCandidates     String    @default("[]")
  gapAreas              String    @default("[]")
  conversationSessionId String    @unique
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([endedAt])
}

// Synthesizer output cache. snapshotKey = "{count}-{maxUpdatedAtIso}" — same
// key means the underlying Self Map hasn't changed and we can reuse the
// previous synthesis. userEditedStatement persists across re-syntheses.
model SelfMapSynthesis {
  id                    String   @id @default(cuid())
  snapshotKey           String   @unique
  identityStatement     String
  userEditedStatement   String?
  citedEntryIds         String   @default("[]")
  tensions              String   @default("[]")
  gaps                  String   @default("[]")
  dismissedTensionKeys  String   @default("[]")
  // Per-entry tags emitted by the Synthesizer for the node map. Shape:
  // { [entryId]: string[] }. Combined with user-edited SelfMapEntry.tags
  // (comma-separated) to compute graph edges (shared tag = edge).
  entryTagsByEntryId    String   @default("{}")
  // Per-category one-line meaning for the canvas. Shape:
  // [{ category: CoreCategory, oneLine: string }]. Renders above each
  // compound category box so clusters carry semantic context, not just color.
  clusterMeanings       String   @default("[]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Closed alpha invite gate. A visitor submits their email on the landing page,
// Mina reviews in /admin/invites and approves (which mints a 10-char code and
// emails it). The code lets the holder log in until Mina revokes it; revoked
// codes are kept for audit but rejected at /api/auth.
model InviteRequest {
  id           String    @id @default(cuid())
  email        String    @unique
  status       String    @default("pending")  // pending | approved | rejected | revoked
  notes        String    @default("")          // Mina memo + reason on reject/revoke
  code         String?   @unique               // 10-char alphanumeric, set on approve
  approvedAt   DateTime?
  rejectedAt   DateTime?
  revokedAt    DateTime?
  emailSentAt  DateTime?
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
